{
  "name": "frontierx-contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node --hostname 0.0.0.0",
    "deploy:local": "hardhat run scripts/deploy-local.ts --network localhost",
    "deploy:network": "hardhat run scripts/deploy-network.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy-network.ts --network sepolia",
    "deploy:polygon": "hardhat run scripts/deploy-network.ts --network polygon",
    "deploy:base": "hardhat run scripts/deploy-network.ts --network base",
    "reveal": "hardhat run scripts/reveal-frontier-pass.ts"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.0.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "dotenv": "^17.2.3",
    "hardhat": "^2.28.6",
    "typescript": "^5.9.3"
  }
}
